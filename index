<!DOCTYPE html>
<html lang="bg">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>The Trap Cocktail Bar | Kapana</title>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;700&family=Playfair+Display:wght@700&display=swap" rel="stylesheet">
    
    <style>
        :root {
            --gold: #b59a6d; /* Златистото от новото лого */
            --dark-btn: #1a1a1a; /* Тъмен фон за бутона за максимален контраст */
            --overlay: rgba(255, 255, 255, 0.45);
        }

        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            /* Пътят към картинката в папката images */
            background: url('images/background.png') no-repeat center center fixed;
            background-size: cover;
            font-family: 'Montserrat', sans-serif;
            color: #1a1a1a;
        }

        .site-wrapper {
            background-color: var(--overlay);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        /* Езиков превключвател */
        .lang-switch {
            text-align: right;
            padding: 20px;
        }
        .lang-btn {
            background: var(--dark-btn);
            color: white;
            border: 1px solid var(--gold);
            padding: 8px 15px;
            cursor: pointer;
            font-weight: bold;
            margin-left: 5px;
            border-radius: 4px;
            transition: 0.3s;
        }
        .lang-btn:hover { background: var(--gold); color: var(--dark-btn); }

        .hero {
            text-align: center;
            padding: 40px 20px;
        }

        .logo {
            max-width: 280px;
            margin-bottom: 30px;
        }

        h1 {
            font-family: 'Playfair Display', serif;
            font-size: 2.2rem;
            max-width: 800px;
            margin: 0 auto 40px;
            line-height: 1.3;
        }

        /* НОВИЯТ КОНТРАСТЕН БУТОН */
        .btn-reserve {
            background-color: var(--dark-btn); /* Тъмен като логото */
            color: var(--gold);              /* Златист текст */
            padding: 22px 50px;
            text-decoration: none;
            font-weight: 700;
            border: 2px solid var(--gold);    /* Златиста рамка */
            border-radius: 5px;
            font-size: 1.3rem;
            display: inline-block;
            box-shadow: 0 8px 20px rgba(0,0,0,0.3);
            transition: all 0.3s ease;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .btn-reserve:hover { 
            transform: translateY(-5px); 
            background-color: var(--gold); 
            color: var(--dark-btn);
            box-shadow: 0 12px 25px rgba(0,0,0,0.4);
        }

        /* Секция Карта */
        .map-section {
            width: 100%;
            max-width: 900px;
            margin: 40px auto;
            padding: 0 20px;
            text-align: center;
        }
        .map-section iframe {
            width: 100%;
            height: 400px;
            border: 2px solid var(--gold);
            border-radius: 12px;
            background: #fff;
        }

        .address {
            font-weight: 700;
            margin: 20px 0;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        /* Социални мрежи */
        .socials {
            text-align: center;
            padding: 40px 0 60px;
        }
        .socials a {
            margin: 0 15px;
            color: #1a1a1a;
            text-decoration: none;
            font-weight: 700;
            font-size: 0.9rem;
            border-bottom: 2px solid var(--gold);
            padding-bottom: 3px;
            transition: 0.3s;
        }
        .socials a:hover { color: var(--gold); }

        @media (max-width: 600px) {
            h1 { font-size: 1.6rem; }
            .btn-reserve { font-size: 1.1rem; width: 90%; padding: 18px 20px; }
        }
    </style>
</head>
<body>

    <div class="site-wrapper">
        <div class="lang-switch">
            <button class="lang-btn" onclick="setLanguage('bg')">BG</button>
            <button class="lang-btn" onclick="setLanguage('en')">EN</button>
        </div>

        <section class="hero">
            <img src="images/TT.png" alt="The Trap Logo" class="logo">
            <h1 id="txt-title">Наслади се на уникални коктейли в сърцето на Капана! Резервирай своята маса сега.</h1>
            <a href="tel:+359879880168" class="btn-reserve" id="txt-btn">Направи резервация</a>
        </section>

        <section class="map-section">
            <iframe 
                src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2958.256247346123!2d24.7475143!3d42.148004!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x14acd1a3962646d1%3A0x673c051939801869!2z0YPQuy4g4oCe0JzQsNCz0YPRgNCw4oCcIDMsIDQwMDAg0KbQtdC90YLRitGALCDQn9C70L7QstC00LjQsg!5e0!3m2!1sbg!2sbg!4v1700000000000!5m2!1sbg!2sbg" 
                allowfullscreen="" 
                loading="lazy">
            </iframe>
            <p class="address" id="txt-addr">Пловдив, ул. Магура № 3</p>
        </section>

        <footer class="socials">
            <a href="https://www.facebook.com/thetrapplovdiv" target="_blank">FACEBOOK</a>
            <a href="https://www.instagram.com/thetrapplovdiv" target="_blank">INSTAGRAM</a>
            <a href="https://www.tiktok.com/@thetrapplovdiv" target="_blank">TIK-TOK</a>
        </footer>
    </div>

    <script>
        function setLanguage(lang) {
            const translations = {
                bg: {
                    title: "Наслади се на уникални коктейли в сърцето на Капана! Резервирай своята маса сега.",
                    btn: "Направи резервация",
                    addr: "Пловдив, ул. Магура № 3"
                },
                en: {
                    title: "Enjoy unique cocktails in the heart of Kapana! Book your table now.",
                    btn: "Make a Reservation",
                    addr: "3 Magura St, Plovdiv"
                }
            };

            document.getElementById('txt-title').innerText = translations[lang].title;
            document.getElementById('txt-btn').innerText = translations[lang].btn;
            document.getElementById('txt-addr').innerText = translations[lang].addr;
        }
    </script>
</body>
</html>
